// Detect if config.php is in the same directory as this file. If so require it.
$configpath = __DIR__ . '/config.php';
if (file_exists($configpath)) {
    define('CLI_SCRIPT', true);
    require_once($configpath);
    require_once($CFG->dirroot . '/local/devkit/cli/run.php');
    die;
}

// This file is likely located at ./local/devkit/bin/devkit
require(__DIR__ . '/../cli/run.php');
