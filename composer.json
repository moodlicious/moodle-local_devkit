{
    "name": "imfelixyeung/moodle-local_devtools",
    "description": "A collection of tools to help with the development of Moodle.",
    "require": {
        "php": ">=8.3",
        "php-debugbar/php-debugbar": "^3.7",
        "symfony/console": "^7.0",
        "mcp/sdk": "^0.4.0",
        "symfony/process": "^7.4"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "micaherne/phpstan-moodle": "^1.0"
    },
    "authors": [
        {
            "name": "Felix Yeung",
            "email": "me@felixyeung.com"
        }
    ],
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        },
        "platform": {
            "php": "8.3"
        }
    }
}